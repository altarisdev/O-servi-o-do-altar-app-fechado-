<!DOCTYPE html>
<html lang="pt-BR" class="transition-colors duration-500">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Altaris - Painel do Acólito</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style type="text/tailwindcss">
        @theme { --animate-pulse: pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @custom-variant dark (&:where(.dark, .dark *));

        .bg-sacro-dourado { background-color: #f8fafc; background-image: url("data:image/svg+xml;base64, dPSJNMzYgMThoOHYyaC-4ek0zNiA5bC-4ek0xOCAzNmgydjhoLTJNNTggMzZoMnY4aC-yeiIvPjwvZz48L3N2Zz4="); }
        .dark .bg-sacro-dourado { background-color: #09090b; background-image: url("data:image/svg+xml;base64,-4ek0zNiA5bC-4ek0xOCAzNmgydjhoLTJNNTggMzZoMnY4aC-yeiIvPjwvZz48L3N2Zz4="); }
        .active-tab { border-bottom: 3px solid #dc2626; color: #dc2626; font-weight: 800; }
        .dark .active-tab { border-bottom: 3px solid #ef4444; color: #ef4444; }
        .active-subtab { background-color: #f3f4f6; color: #1f2937; font-weight: 700; }
        .dark .active-subtab { background-color: #27272a; color: #f4f4f5; }
    </style>
</head>
<body class="bg-sacro-dourado font-sans min-h-screen flex flex-col transition-colors duration-500 selection:bg-red-200">

    <main class="max-w-6xl w-full mx-auto p-4 md:p-6 flex-1 grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Estrutura mantida conforme seu original -->
        <div id="conteudo-escala" class="space-y-6 block md:col-span-2">
            <div class="bg-white dark:bg-zinc-900 rounded-3xl p-6 border border-slate-100 dark:border-zinc-800">
                <div id="resultado-escala-geral" class="space-y-5 text-xs"></div>
            </div>
        </div>
    </main>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getAuth, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
    import { getFirestore, doc, updateDoc, getDoc, collection, onSnapshot } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCwPeLrAtNEO41MZ3yxSuYib2LC0z2dv9U",
        authDomain: "tarcisius-d03d7.firebaseapp.com",
        projectId: "tarcisius-d03d7",
        storageBucket: "tarcisius-d03d7.firebasestorage.app",
        messagingSenderId: "186797936591",
        appId: "1:186797936591:web:72c81c54fb7c1905c1ccba"
    };

    const app = initializeApp(firebaseConfig); 
    const auth = getAuth(app); 
    const db = getFirestore(app);

    let usuarioLogadoDados = null; 
    let todasEscalasCache = [];

    // Função global de atualização
    window.votarPresencaItem = async function(idDocEscala, campoFuncao, novoStatus) {
        if(!idDocEscala || !campoFuncao) return;
        const refDoc = doc(db, "escalas", idDocEscala);
        const dUp = {};
        dUp[`${campoFuncao}.status`] = novoStatus;
        try {
            await updateDoc(refDoc, dUp);
        } catch (error) {
            console.error("Erro:", error);
            alert("Erro ao atualizar status.");
        }
    };

    window.assumirVagaEscala = async function(idDocEscala, campoFuncao, operacao) {
        if(!idDocEscala || !campoFuncao) return;
        const refDoc = doc(db, "escalas", idDocEscala);
        const dUp = {};
        dUp[`${campoFuncao}.status`] = "Confirmado";
        if (operacao !== 'Voltar') dUp[`${campoFuncao}.nome`] = usuarioLogadoDados.nome;
        
        try {
            await updateDoc(refDoc, dUp);
            alert("Sucesso!");
        } catch (error) {
            alert("Erro ao processar.");
        }
    };

    async function verificarFaltasAutomaticas(escalas) {
        const agora = new Date();
        const campos = ['altar1', 'altar2', 'altar3', 'altar4', 'altar5', 'altar6', 'turiferario', 'naveteiro'];
        
        for (const esc of escalas) {
            const dataEscala = new Date(`${esc.data}T${esc.horario}:00`);
            // Tolerância de 60 minutos após o horário
            if (agora > new Date(dataEscala.getTime() + 60 * 60 * 1000)) {
                for (const c of campos) {
                    if (esc[c] && esc[c].status === 'Pendente') {
                        const dUp = {};
                        dUp[`${c}.status`] = "Falta";
                        await updateDoc(doc(db, "escalas", esc.idDoc), dUp);
                    }
                }
            }
        }
    }

    onAuthStateChanged(auth, async (user) => {
        if(user) {
            const docSnap = await getDoc(doc(db, "usuarios", user.uid));
            if(docSnap.exists()) { 
                usuarioLogadoDados = docSnap.data(); 
                inicializarPainel(); 
            }
        }
    });

    function inicializarPainel() {
        onSnapshot(collection(db, "escalas"), (snap) => {
            todasEscalasCache = [];
            snap.forEach(d => { 
                const e = d.data(); 
                e.idDoc = d.id; 
                todasEscalasCache.push(e); 
            });
            verificarFaltasAutomaticas(todasEscalasCache);
        });
    }
</script>
</body>
</html>
