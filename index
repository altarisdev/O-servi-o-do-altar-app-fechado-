                    return;
                }

                rodarSorteioMensal();
            } catch (error) { console.error(error); }
        }

        function embaralhar(array) {
            let lista = [...array];
            for (let i = lista.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [lista[i], lista[j]] = [lista[j], lista[i]];
            }
            return lista;
        }

        function romanize(num) {
            const lookup = {M:1000,CM:900,D:500,CD:400,C:100,XC:90,L:50,XL:40,X:10,IX:9,V:5,IV:4,I:1};
            let roman = '';
            for (let i in lookup) { while (num >= lookup[i]) { roman += i; num -= lookup[i]; } }
            return roman;
        }

        function rodarSorteioMensal() {
            if (membrosDisponiveisMensal.length === 0) return;
            const sorteados = embaralhar(membrosDisponiveisMensal);
            
            escalaMensalAtual = {
                "Altar I": sorteados[0] || "",
                "Altar II": sorteados[1] || "",
                "Altar III": sorteados[2] || "",
                "Altar IV": sorteados[3] || "",
                "Altar V": sorteados[4] || "",
                "Altar VI": sorteados[5] || "",
                "Turíbulo": sorteados[6] || "",
                "Naveta": sorteados[7] || ""
            };
            renderizarPainelMensal();
        }

        function renderizarPainelMensal() {
            containerAltarMensal.innerHTML = "";
            listaDisponiveisMensal.innerText = membrosDisponiveisMensal.join(", ");
            const molde = selectMoldeCelebração.value;

            // Se for comum, esconde a aba visual do Incenso da tela
            if (molde === 'comum') {
                document.getElementById('bloco-incenso-manual').classList.add('opacity-40', 'pointer-events-none');
            } else {
                document.getElementById('bloco-incenso-manual').classList.remove('opacity-40', 'pointer-events-none');
            }

            // Define limite de pessoas no Altar baseado na Ideia 3 (Comum = 3 acólitos, Solene = 6)
            const limiteAltar = molde === 'comum' ? 3 : 6;

            for (let i = 1; i <= limiteAltar; i++) {
                const funcao = `Altar ${romanize(i)}`;
                const selecionado = escalaMensalAtual[funcao];

                const div = document.createElement('div');
                div.className = "flex items-center justify-between bg-white p-2 rounded-xl border border-gray-200 gap-2";
                div.innerHTML = `
                    <span class="text-xs font-bold text-gray-600 w-16">${funcao}:</span>
                    <select data-funcao="${funcao}" class="select-membro-mensal flex-1 border p-1 rounded-md text-xs bg-gray-50">
                        <option value="">-- Vago --</option>
                        ${membrosDisponiveisMensal.map(m => `<option value="${m}" ${m === selecionado ? 'selected' : ''}>${m}</option>`).join('')}
                    </select>
                `;
                containerAltarMensal.appendChild(div);
            }

            popularSelectIncenso(selectTuribuloMensal, escalaMensalAtual["Turíbulo"]);
            popularSelectIncenso(selectNavetaMensal, escalaMensalAtual["Naveta"]);

            document.querySelectorAll('.select-membro-mensal').forEach(element => {
                element.addEventListener('change', (e) => {
                    let funcaoMapeada = e.target.getAttribute('data-funcao');
                    if (!funcaoMapeada) {
                        funcaoMapeada = e.target.id === 'select-turibulo-mensal' ? 'Turíbulo' : 'Naveta';
                    }
                    escalaMensalAtual[funcaoMapeada] = e.target.value;
                });
            });
        }

        function popularSelectIncenso(elementoDOM, selecionado) {
            elementoDOM.innerHTML = `<option value="">-- Escolha --</option>
