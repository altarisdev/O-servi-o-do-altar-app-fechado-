                if (membrosDisponiveisMensal.length === 0) {
                    containerAltarMensal.innerHTML = '<p class="text-xs text-rose-600 font-bold"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Sem registros mapeados para este bloco.</p>';
