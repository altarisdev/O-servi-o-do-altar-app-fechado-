        async function carregarMembrosEnqueteMensal() {
            const horario = selectHorarioMensal.value;
            membrosDisponiveisMensal = [];
            containerAltarMensal.innerHTML = '<p class="text-xs text-gray-400 italic"><i class="fa-solid fa-spinner animate-spin mr-1"></i> Cruzando dados e restrições...</p>';
            
