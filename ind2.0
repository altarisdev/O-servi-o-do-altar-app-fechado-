<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Serviço do Altar - Tarcisius</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .active-tab { border-bottom: 3px solid #b45309; color: #b45309; font-weight: bold; }
    </style>
</head>
<body class="bg-gray-100 font-sans min-h-screen flex flex-col">

    <div id="tela-login" class="fixed inset-0 bg-amber-900 flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl p-6 space-y-6">
            <div class="text-center space-y-2">
                <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto text-amber-700 text-3xl shadow-sm">
                    <i class="fa-solid fa-cross"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-800">Tarcisius Admin</h2>
                <p class="text-xs text-gray-500">Gestão de Coroinhas e Acólitos</p>
            </div>

            <form id="form-login" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase mb-1">E-mail de Acesso</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-envelope"></i>
                        </span>
                        <input type="email" id="login-email" required placeholder="seu-email@igreja.com" 
                            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 border border-gray-300 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-amber-600 focus:bg-white transition-all">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Senha</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input type="password" id="login-senha" required placeholder="••••••" 
                            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 border border-gray-300 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-amber-600 focus:bg-white transition-all">
                    </div>
                </div>

                <div id="erro-login" class="text-xs text-rose-600 font-bold hidden bg-rose-50 p-2 rounded-lg border border-rose-200">
                    <i class="fa-solid fa-circle-exclamation mr-1"></i> E-mail ou senha incorretos.
                </div>

                <button type="submit" class="w-full bg-amber-700 text-white font-bold py-3 rounded-xl hover:bg-amber-800 shadow-md transition-all cursor-pointer text-sm">
                    <i class="fa-solid fa-right-to-bracket mr-1"></i> Entrar no Sistema
                </button>
            </form>
        </div>
    </div>

    <div id="sistema-conteudo" class="hidden flex-col min-h-screen">
        
        <header class="bg-amber-700 text-white shadow-md p-4 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <i class="fa-solid fa-cross text-2xl text-amber-200"></i>
                    <div>
                        <h1 id="nome-usuario-header" class="text-xl font-bold leading-none">Carregando...</h1>
                        <p id="funcao-usuario-header" class="text-xs text-amber-100">Verificando permissões...</p>
                    </div>
                </div>
                <button id="btn-logout" class="text-amber-100 hover:text-white text-sm font-bold flex items-center gap-1 cursor-pointer">
                    <i class="fa-solid fa-power-off"></i> <span>Sair</span>
                </button>
            </div>
        </header>

        <nav id="menu-abas-coroinha" class="bg-white shadow-sm border-b border-gray-200 flex justify-around sticky top-[68px] z-40 md:hidden">
            <button id="tab-escala" class="active-tab flex-1 py-3 text-center text-sm flex flex-col items-center gap-1"><i class="fa-solid fa-calendar-days text-lg"></i> Escalas</button>
            <button id="tab-avisos" class="text-gray-500 flex-1 py-3 text-center text-sm flex flex-col items-center gap-1"><i class="fa-solid fa-bell text-lg"></i> Avisos</button>
            <button id="tab-liturgia" class="text-gray-500 flex-1 py-3 text-center text-sm flex flex-col items-center gap-1"><i class="fa-solid fa-book-bible text-lg"></i> Liturgia</button>
        </nav>

        <main id="painel-coroinha" class="hidden flex-1 p-4 max-w-7xl mx-auto w-full grid grid-cols-1 md:grid-cols-3 gap-6 pb-20">
            <section id="conteudo-escala" class="space-y-4">
                <div class="flex items-center justify-between">
                    <h3 class="font-bold text-gray-800 text-lg"><i class="fa-solid fa-list-check text-amber-700 mr-1"></i> Próximas Escalas</h3>
                    <input type="date" id="busca-escala-data" class="text-xs bg-white border p-1 rounded-md text-gray-700 font-semibold">
                </div>
                
                <div id="card-enquete" class="bg-blue-50 border-l-4 border-blue-600 p-4 rounded-r-xl shadow-xs hidden">
                    <div class="flex gap-3">
                        <i class="fa-solid fa-circle-question text-blue-600 text-xl mt-0.5"></i>
                        <div class="flex-1 space-y-2">
                            <h4 class="font-bold text-blue-900 text-sm">Pesquisa de Disponibilidade Mensal</h4>
                            <p class="text-xs text-blue-800" id="txt-pergunta-enquete">Selecione quais horários você pode servir nas escalas:</p>
                            
                            <div id="container-opcoes-enquete" class="space-y-1.5 text-xs text-gray-700 bg-white p-3 rounded-lg border border-blue-100">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="horarios-voto" value="terca_19" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                    <span>Terça-feira – 19:00</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="horarios-voto" value="quinta_17" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                    <span>Quinta-feira – 17:00</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="horarios-voto" value="sabado_19" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                    <span>Sábado – 19:00</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="horarios-voto" value="domingo_09" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                    <span>Domingo – 09:00</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="horarios-voto" value="domingo_19" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                    <span>Domingo – 19:00</span>
                                </label>
                            </div>

                            <div class="flex gap-2 pt-1" id="botoes-enquete">
                                <button id="btn-enquete-salvar" class="bg-blue-600 text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-blue-700 flex-1 cursor-pointer shadow-xs">
                                    <i class="fa-solid fa-paper-plane mr-1"></i> Enviar Respostas
                                </button>
                            </div>
                            <p id="txt-feedback-enquete" class="text-xs font-bold mt-2 text-emerald-700 hidden">✓ Suas disponibilidades foram gravadas!</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="bg-gray-800 text-white p-3 flex justify-between items-center">
                        <div>
                            <span class="text-xs bg-amber-600 font-bold px-2 py-0.5 rounded-sm" id="lbl-data-missa">--/--/----</span>
                            <h4 id="lbl-titulo-missa" class="font-bold text-sm mt-0.5">Selecione uma data acima</h4>
                        </div>
                        <div class="text-right text-xs"><p class="font-bold" id="lbl-horario-missa">--:--h</p></div>
                    </div>
                    <div class="divide-y divide-gray-100" id="lista-presbiterio"></div>
                </div>

                <div id="card-notificacao" class="bg-amber-50 border border-amber-200 p-4 rounded-xl shadow-xs hidden">
                    <p class="text-xs text-amber-800 font-medium">Você faz parte desta escala! Por favor, confirme ou recuse:</p>
                    <div class="flex gap-2 mt-2" id="botoes-acao">
                        <button id="btn-confirmar" class="bg-emerald-600 text-white text-xs font-bold px-3 py-2 rounded-lg hover:bg-emerald-700 flex-1 cursor-pointer">✓ Confirmar</button>
                        <button id="btn-recusar" class="bg-rose-600 text-white text-xs font-bold px-3 py-2 rounded-lg hover:bg-rose-700 flex-1 cursor-pointer">✕ Pedir Troca</button>
                    </div>
                    <p id="txt-feedback" class="text-xs font-bold mt-2 hidden"></p>
                </div>
            </section>

            <section id="conteudo-avisos" class="space-y-4 hidden md:block">
                <h3 class="font-bold text-gray-800 text-lg"><i class="fa-solid fa-bullhorn text-amber-700 mr-1"></i> Mural</h3>
                <div class="bg-white p-4 rounded-xl border text-xs text-gray-600">Nenhum comunicado urgente hoje.</div>
            </section>

            <section id="conteudo-liturgia" class="space-y-4 hidden md:block">
                <h3 class="font-bold text-gray-800 text-lg"><i class="fa-solid fa-book-open text-amber-700 mr-1"></i> Liturgia e Estudos</h3>
                <div class="bg-amber-900 text-amber-100 p-4 rounded-xl shadow-sm">
                    <div class="flex justify-between items-center border-b border-amber-800 pb-1 mb-2">
                        <span class="text-[10px] uppercase font-bold text-amber-300">Evangelho de Hoje</span>
                        <span id="lbl-ref-liturgia" class="text-xs font-bold text-amber-200">---</span>
                    </div>
                    <p id="txt-evangelho-dia" class="text-xs italic max-h-48 overflow-y-auto">Carregando...</p>
                </div>
                <div class="bg-white p-4 rounded-xl border">
                    <h4 class="font-bold text-gray-800 text-sm">Material de Apoio</h4>
                    <p id="lbl-titulo-formacao" class="text-xs text-gray-600 mt-1">Baixe os manuais litúrgicos.</p>
                    <a id="btn-download-formacao" href="#" target="_blank" class="w-full block text-center mt-3 bg-amber-50 text-amber-800 border text-xs font-bold py-2 rounded-lg hover:bg-amber-100">Abrir Documento</a>
                </div>
            </section>
        </main>

        <main id="painel-coordenador" class="hidden flex-1 p-4 max-w-6xl mx-auto w-full space-y-6 pb-20">
            
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-center justify-between shadow-xs">
                <div>
                    <h2 class="text-lg font-bold text-amber-900">Painel Geral da Coordenação</h2>
                    <p class="text-xs text-amber-700">Gestão integrada de escalas, monitoramento de enquetes e controle de contas.</p>
                </div>
                <i class="fa-solid fa-user-shield text-3xl text-amber-700"></i>
            </div>

            <div class="bg-white p-5 rounded-2xl border border-gray-200 space-y-4">
                <div class="flex items-center justify-between border-b pb-2">
                    <h3 class="font-bold text-gray-800"><i class="fa-solid fa-calendar-days text-amber-700 mr-1"></i> Engenharia de Escala Mensal por Horário</h3>
                    <span class="text-[10px] bg-blue-100 text-blue-800 px-2 py-0.5 rounded font-bold uppercase">Sorteador Inteligente</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="md:col-span-2 space-y-4">
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Selecione o Fluxo da Enquete:</label>
                            <select id="select-horario-mensal" class="w-full md:w-64 border p-2 text-sm rounded-lg bg-gray-50">
                                <option value="terca_19">Terça-feira – 19:00</option>
                                <option value="quinta_17">Quinta-feira – 17:00</option>
                                <option value="sabado_19">Sábado – 19:00</option>
                                <option value="domingo_09" selected>Domingo – 09:00</option>
                                <option value="domingo_19">Domingo – 19:00</option>
                            </select>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 space-y-3">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-xs font-bold text-gray-700 uppercase">Distribuição do Presbitério</span>
                                <button type="button" id="btn-reordenar-mensal" class="text-[11px] bg-amber-700 hover:bg-amber-800 text-white font-bold py-1 px-3 rounded-md transition-all">
                                    <i class="fa-solid fa-shuffle mr-1"></i> Rodar Sorteio Aleatório
                                </button>
                            </div>
                            
                            <div id="container-altar-mensal" class="space-y-2">
                                <p class="text-xs text-gray-400 italic">Selecione um horário ou aguarde o carregamento...</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="bg-amber-50/60 p-4 rounded-xl border border-amber-200 space-y-3">
                            <span class="text-xs font-bold text-amber-900 uppercase block"><i class="fa-solid fa-smog mr-1"></i> Equipe do Incenso (Manual)</span>
                            <div>
                                <label class="block text-[11px] font-semibold text-amber-800 mb-1">Turíbulo</label>
                                <select id="select-turibulo-mensal" class="w-full border p-2 text-xs rounded-lg bg-white select-membro-mensal"></select>
                            </div>
                            <div>
                                <label class="block text-[11px] font-semibold text-amber-800 mb-1">Naveta</label>
                                <select id="select-naveta-mensal" class="w-full border p-2 text-xs rounded-lg bg-white select-membro-mensal"></select>
                            </div>
                        </div>

                        <div class="bg-blue-50/60 p-4 rounded-xl border border-blue-200">
                            <span class="text-xs font-bold text-blue-900 uppercase block mb-1"><i class="fa-solid fa-users mr-1"></i> Disponíveis na Enquete:</span>
                            <div id="lista-disponiveis-mensal" class="text-xs text-blue-800 font-medium leading-relaxed max-h-24 overflow-y-auto">
                                Nenhum membro mapeado.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end pt-2 border-t">
                    <button type="button" id="btn-salvar-escala-mensal" class="bg-emerald-700 text-white text-xs font-bold py-2.5 px-6 rounded-lg hover:bg-emerald-800 transition-all shadow-xs">
                        <i class="fa-solid fa-cloud-arrow-up mr-1"></i> Salvar Bloco de Escala Mensal
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="bg-white p-5 rounded-2xl border border-gray-200 space-y-4 lg:col-span-2">
                    <h3 class="font-bold text-gray-800 border-b pb-2"><i class="fa-solid fa-calendar-plus text-amber-700 mr-1"></i> Publicar Escala por Data</h3>
                    <form id="form-nova-escala" class="space-y-3">
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Data da Escala</label>
                                <input type="date" id="esc-data" required class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Horário</label>
                                <input type="time" id="esc-horario" required class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Título da Celebração</label>
                            <input type="text" id="esc-titulo" required placeholder="Ex: Missa Dominical - Matriz" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Turiferário</label>
                                <input type="text" id="esc-turi" required placeholder="Nome" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Naveteiro</label>
                                <input type="text" id="esc-nave" required placeholder="Nome" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Crucífero</label>
                                <input type="text" id="esc-cruz" required placeholder="Nome" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-amber-700 text-white text-xs font-bold py-2.5 rounded-lg hover:bg-amber-800 cursor-pointer">Salvar Escala</button>
                    </form>
                </div>

                <div class="bg-white p-5 rounded-2xl border border-gray-200 flex flex-col justify-between space-y-4">
                    <div>
                        <h3 class="font-bold text-gray-800 border-b pb-2"><i class="fa-solid fa-square-poll-horizontal text-amber-700 mr-1"></i> Controle da Enquete</h3>
                        <div class="space-y-3 mt-3">
                            <input type="text" id="enq-pergunta" value="Marque suas disponibilidades para as próximas escalas." class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            <div class="flex gap-2">
                                <button id="btn-disparar-enquete" class="bg-blue-600 text-white text-xs font-bold py-2 px-3 rounded-lg hover:bg-blue-700 flex-1 cursor-pointer">Abrir Enquete</button>
                                <button id="btn-fechar-enquete" class="bg-gray-500 text-white text-xs font-bold py-2 px-3 rounded-lg hover:bg-gray-600 cursor-pointer">Fechar</button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-gray-50 p-3 rounded-xl border space-y-2 mt-2">
                        <p class="text-xs font-bold text-gray-700 uppercase tracking-wider">Mapeamento Geral de Votos:</p>
                        <div class="text-[11px] text-gray-500 max-h-36 overflow-y-auto pt-1 space-y-1" id="lista-nomes-enquete">
                            Aguardando abertura...
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white p-5 rounded-2xl border border-gray-200 space-y-4 md:col-span-2">
                    <h3 class="font-bold text-gray-800 border-b pb-2"><i class="fa-solid fa-user-plus text-amber-700 mr-1"></i> Cadastrar Novo Membro</h3>
                    <form id="form-cadastro-usuario" class="space-y-3">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Nome Completo</label>
                                <input type="text" id="cad-nome" required placeholder="Ex: Lucas Silva" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">E-mail de Acesso</label>
                                <input type="email" id="cad-email" required placeholder="nome@email.com" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                            </div>
                        </div>
                        <div class="flex items-end gap-2 bg-gray-50 p-3 rounded-xl border">
                            <div class="flex-1">
                                <label class="block text-xs font-bold text-amber-900 mb-1"><i class="fa-solid fa-key mr-1"></i> Senha de Acesso</label>
                                <input type="text" id="cad-senha" required class="w-full border p-2 text-sm rounded-lg bg-white font-mono" placeholder="Clique ao lado para gerar">
                            </div>
                            <button type="button" id="btn-gerar-senha" class="bg-amber-700 text-white text-xs font-bold px-4 py-3 rounded-lg hover:bg-amber-800 shadow-xs cursor-pointer h-[40px]">
                                <i class="fa-solid fa-wand-magic-sparkles mr-1"></i> Gerar Senha
                            </button>
                        </div>
                        <button type="submit" class="w-full bg-emerald-700 text-white text-xs font-bold py-2.5 rounded-lg hover:bg-emerald-800 cursor-pointer">Registrar e Armazenar Usuário</button>
                    </form>
                </div>

                <div class="bg-white p-5 rounded-2xl border border-gray-200 space-y-4">
                    <h3 class="font-bold text-gray-800 border-b pb-2"><i class="fa-solid fa-cloud-arrow-up text-amber-700 mr-1"></i> Material de Apoio (PDF)</h3>
                    <form id="form-upload-formacao" class="space-y-3">
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Título do Arquivo</label>
                            <input type="text" id="form-titulo-input" required placeholder="Ex: Manual do Coroinha v3" class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Link URL</label>
                            <input type="url" id="form-url-input" required placeholder="https://drive.google.com/..." class="w-full border p-2 text-sm rounded-lg bg-gray-50">
                        </div>
                        <button type="submit" class="w-full bg-amber-800 text-white text-xs font-bold py-2 rounded-lg hover:bg-amber-900 cursor-pointer">Atualizar Link</button>
                    </form>
                </div>
            </div>

            <div class="bg-white p-5 rounded-2xl border border-gray-200 space-y-4">
                <div class="flex items-center justify-between border-b pb-2">
                    <h3 class="font-bold text-gray-800"><i class="fa-solid fa-address-book text-amber-700 mr-1"></i> Central de Recuperação de Acessos</h3>
                    <span class="text-[10px] bg-amber-100 text-amber-800 px-2 py-0.5 rounded font-bold uppercase">Lista de Consulta</span>
                </div>
                <p class="text-xs text-gray-500">Abaixo constam as credenciais criadas para suporte imediato aos pais ou coroinhas que perderem o acesso.</p>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-gray-100 text-gray-600 uppercase text-[10px] tracking-wider border-b border-gray-200">
                                <th class="p-3 font-bold">Nome do Membro</th>
                                <th class="p-3 font-bold">E-mail cadastrado</th>
                                <th class="p-3 font-bold">Última Senha Salva</th>
                                <th class="p-3 font-bold text-center">Tipo</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-usuarios-recuperacao" class="divide-y divide-gray-100 text-gray-700">
                            <tr>
                                <td colspan="4" class="p-4 text-center text-gray-400 italic">Carregando carteira de acessos do Firestore...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>

        <footer class="bg-gray-800 text-gray-400 text-center text-[11px] py-3 mt-auto border-t border-gray-700">
            <p>© 2026 Tarcisius System — Cloud Firestore Integrado</p>
        </footer>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged, createUserWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, updateDoc, arrayUnion, collection, onSnapshot, query, where, getDocs, deleteDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCwPeLrAtNEO41MZ3yxSuYib2LC0z2dv9U",
            authDomain: "tarcisius-d03d7.firebaseapp.com",
            projectId: "tarcisius-d03d7",
            storageBucket: "tarcisius-d03d7.firebasestorage.app",
            messagingSenderId: "186797936591",
            appId: "1:186797936591:web:72c81c54fb7c1905c1ccba"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        // Referências Gerais do DOM
        const formLogin = document.getElementById('form-login');
        const erroLogin = document.getElementById('erro-login');
        const btnLogout = document.getElementById('btn-logout');
        const telaLogin = document.getElementById('tela-login');
        const sistemaConteudo = document.getElementById('sistema-conteudo');
        const nomeUsuarioHeader = document.getElementById('nome-usuario-header');
        const funcaoUsuarioHeader = document.getElementById('funcao-usuario-header');
        const painelCoroinha = document.getElementById('painel-coroinha');
        const painelCoordenador = document.getElementById('painel-coordenador');
        const menuAbasCoroinha = document.getElementById('menu-abas-coroinha');
        const buscaEscalaData = document.getElementById('busca-escala-data');

        // Referências do Gerenciador Mensal
        const selectHorarioMensal = document.getElementById('select-horario-mensal');
        const containerAltarMensal = document.getElementById('container-altar-mensal');
        const selectTuribuloMensal = document.getElementById('select-turibulo-mensal');
        const selectNavetaMensal = document.getElementById('select-naveta-mensal');
        const listaDisponiveisMensal = document.getElementById('lista-disponiveis-mensal');
        const btnReordenarMensal = document.getElementById('btn-reordenar-mensal');
        const btnSalvarEscalaMensal = document.getElementById('btn-salvar-escala-mensal');

        let usuarioLogadoDados = null;
        let dataSelecionadaGlobal = "";
        
        let membrosDisponiveisMensal = [];
        let escalaMensalAtual = {};

        // CONTROLADOR DE SESSÕES
        onAuthStateChanged(auth, async (user) => {
            if (user) {
                try {
                    const docSnap = await getDoc(doc(db, "usuarios", user.uid));
                    if (docSnap.exists()) {
                        usuarioLogadoDados = docSnap.data();
                        usuarioLogadoDados.uid = user.uid;
                        nomeUsuarioHeader.innerText = "Salve, " + usuarioLogadoDados.nome;
                        funcaoUsuarioHeader.innerText = "Acesso: " + usuarioLogadoDados.funcao;

                        if (usuarioLogadoDados.funcao === "Coordenador") {
                            painelCoroinha.classList.add('hidden');
                            menuAbasCoroinha.classList.add('hidden');
                            painelCoordenador.classList.remove('hidden');
                            
                            ouvirRespostasEnquetePainel();
                            ouvirUsuariosCadastrados();
                            carregarMembrosEnqueteMensal();
                        } else {
                            painelCoordenador.classList.add('hidden');
                            painelCoroinha.classList.remove('hidden');
                            menuAbasCoroinha.classList.remove('hidden');
                            
                            const hoje = new Date().toISOString().split('T')[0];
                            buscaEscalaData.value = hoje;
                            
                            checarEnqueteAtiva();
                            carregarEscalaPorData(hoje);
                            carregarLiturgiaAutomatica();
                            carregarMaterialEstudo();
                        }
                    }
                    telaLogin.style.display = 'none';
                    sistemaConteudo.style.display = 'flex';
                } catch (e) { console.error(e); }
            } else {
                sistemaConteudo.style.display = 'none';
                telaLogin.style.display = 'flex';
            }
        });

        formLogin.addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                await signInWithEmailAndPassword(auth, document.getElementById('login-email').value, document.getElementById('login-senha').value);
                erroLogin.className = 'hidden';
            } catch (err) { erroLogin.className = 'text-xs text-rose-600 font-bold bg-rose-50 p-2 rounded-lg border border-rose-200 block'; }
        });
        btnLogout.addEventListener('click', () => signOut(auth));


        // ========================================================
        // ENGENHARIA DE ESCALA MENSAL POR HORÁRIO
        // ========================================================
        selectHorarioMensal.addEventListener('change', carregarMembrosEnqueteMensal);
        btnReordenarMensal.addEventListener('click', rodarSorteioMensal);
        btnSalvarEscalaMensal.addEventListener('click', salvarEscalaMensalFirestore);

        async function carregarMembrosEnqueteMensal() {
            const horario = selectHorarioMensal.value;
            membrosDisponiveisMensal = [];
            containerAltarMensal.innerHTML = '<p class="text-xs text-gray-400 italic"><i class="fa-solid fa-spinner animate-spin mr-1"></i> Buscando banco de respostas...</p>';
            
            try {
                // Busca na coleção respostas_enquete onde o horário selecionado está marcado como TRUE
                const q = query(collection(db, "respostas_enquete"), where("horario", "==", horario), where("disponivel", "==", true));
                const querySnapshot = await getDocs(q);
                
                querySnapshot.forEach((doc) => {
                    membrosDisponiveisMensal.push(doc.data().nomeMembro);
                });

                if (membrosDisponiveisMensal.length === 0) {
                    containerAltarMensal.innerHTML = '<p class="text-xs text-rose-600 font-bold"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Nenhum acólito disponível para este horário.</p>';
                    listaDisponiveisMensal.innerText = "Nenhum.";
                    return;
                }

                rodarSorteioMensal();
            } catch (error) { console.error(error); }
        }

        function embaralhar(array) {
            let lista = [...array];
            for (let i = lista.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [lista[i], lista[j]] = [lista[j], lista[i]];
            }
            return lista;
        }

        function romanize(num) {
            const lookup = {M:1000,CM:900,D:500,CD:400,C:100,XC:90,L:50,XL:40,X:10,IX:9,V:5,IV:4,I:1};
            let roman = '';
            for (let i in lookup) { while (num >= lookup[i]) { roman += i; num -= lookup[i]; } }
            return roman;
        }

        function rodarSorteioMensal() {
            if (membrosDisponiveisMensal.length === 0) return;
            const sorteados = embaralhar(membrosDisponiveisMensal);
            
            escalaMensalAtual = {
                "Altar I": sorteados[0] || "",
                "Altar II": sorteados[1] || "",
                "Altar III": sorteados[2] || "",
                "Altar IV": sorteados[3] || "",
                "Altar V": sorteados[4] || "",
                "Altar VI": sorteados[5] || "",
                "Turíbulo": sorteados[6] || "",
                "Naveta": sorteados[7] || ""
            };
            renderizarPainelMensal();
        }

        function renderizarPainelMensal() {
            containerAltarMensal.innerHTML = "";
            listaDisponiveisMensal.innerText = membrosDisponiveisMensal.join(", ");

            for (let i = 1; i <= 6; i++) {
                const funcao = `Altar ${romanize(i)}`;
                const selecionado = escalaMensalAtual[funcao];

                const div = document.createElement('div');
                div.className = "flex items-center justify-between bg-white p-2 rounded-xl border border-gray-200 gap-2";
                div.innerHTML = `
                    <span class="text-xs font-bold text-gray-600 w-16">${funcao}:</span>
                    <select data-funcao="${funcao}" class="select-membro-mensal flex-1 border p-1 rounded-md text-xs bg-gray-50 focus:bg-white focus:outline-hidden transition-all">
                        <option value="">-- Vago --</option>
                        ${membrosDisponiveisMensal.map(m => `<option value="${m}" ${m === selecionado ? 'selected' : ''}>${m}</option>`).join('')}
                    </select>
                `;
                containerAltarMensal.appendChild(div);
            }

            popularSelectIncenso(selectTuribuloMensal, escalaMensalAtual["Turíbulo"]);
            popularSelectIncenso(selectNavetaMensal, escalaMensalAtual["Naveta"]);

            document.querySelectorAll('.select-membro-mensal').forEach(element => {
                element.addEventListener('change', (e) => {
                    let funcaoMapeada = e.target.getAttribute('data-funcao');
                    if (!funcaoMapeada) {
                        funcaoMapeada = e.target.id === 'select-turibulo-mensal' ? 'Turíbulo' : 'Naveta';
                    }
                    escalaMensalAtual[funcaoMapeada] = e.target.value;
                });
            });
        }

        function popularSelectIncenso(elementoDOM, selecionado) {
            elementoDOM.innerHTML = `<option value="">-- Escolha --</option>
                ${membrosDisponiveisMensal.map(m => `<option value="${m}" ${m === selecionado ? 'selected' : ''}>${m}</option>`).join('')}`;
        }

        async function salvarEscalaMensalFirestore() {
            const horario = selectHorarioMensal.value;
            btnSalvarEscalaMensal.disabled = true;
            btnSalvarEscalaMensal.innerHTML = '<i class="fa-solid fa-spinner animate-spin mr-1"></i> Processando...';
            
            try {
                await setDoc(doc(db, "escalas_mensais", horario), {
                    horario: horario,
                    escala: escalaMensalAtual,
                    atualizadoEm: new Date().toISOString()
                });
                alert("Sucesso! Bloco de Escala Mensal gravado.");
            } catch (err) { alert("Erro ao salvar escala."); }
            finally {
                btnSalvarEscalaMensal.disabled = false;
                btnSalvarEscalaMensal.innerHTML = '<i class="fa-solid fa-cloud-arrow-up mr-1"></i> Salvar Bloco de Escala Mensal';
            }
        }


        // ========================================================
        // NOVA LOGICA DA ENQUETE BASEADA EM HORÁRIOS (COROINHA)
        // ========================================================
        async function checarEnqueteAtiva() {
            const docSnap = await getDoc(doc(db, "enquetes", "disponibilidade_atual"));
            if(docSnap.exists() && docSnap.data().ativa === true) {
                document.getElementById('card-enquete').classList.remove('hidden');
                document.getElementById('botoes-enquete').classList.remove('hidden');
                document.getElementById('txt-feedback-enquete').classList.add('hidden');
                
                // Limpa as seleções antigas
                document.querySelectorAll('input[name="horarios-voto"]').forEach(cb => cb.checked = false);
            } else { 
                document.getElementById('card-enquete').classList.add('hidden'); 
            }
        }

        document.getElementById('btn-enquete-salvar').addEventListener('click', async () => {
            const checkboxes = document.querySelectorAll('input[name="horarios-voto"]');
            const btnSalvar = document.getElementById('btn-enquete-salvar');
            
            btnSalvar.disabled = true;
            btnSalvar.innerText = "Enviando...";

            try {
                // Loop para rodar todas as opções e salvar de forma individual estruturada
                for (let cb of checkboxes) {
                    const horarioId = cb.value;
                    const estaDisponivel = cb.checked;
                    const docId = `${usuarioLogadoDados.uid}_${horarioId}`;

                    // Salva ou remove o direito de sorteio na coleção principal
                    await setDoc(doc(db, "respostas_enquete", docId), {
                        uidUsuario: usuarioLogadoDados.uid,
                        nomeMembro: usuarioLogadoDados.nome,
                        horario: horarioId,
                        disponivel: estaDisponivel,
                        respondidoEm: new Date().toISOString()
                    });
                }

                // Salva uma cópia na central histórica de enquetes para visualização do coordenador
                const opcoesMarcadas = Array.from(checkboxes).filter(c => c.checked).map(c => c.value);
                await setDoc(doc(db, "votos_enquete_sumario", usuarioLogadoDados.uid), {
                    nomeMembro: usuarioLogadoDados.nome,
                    horariosDisponiveis: opcoesMarcadas,
                    atualizadoEm: new Date().toISOString()
                });

                document.getElementById('botoes-enquete').classList.add('hidden');
                document.getElementById('txt-feedback-enquete').classList.remove('hidden');
            } catch (error) {
                console.error(error);
                alert("Erro ao enviar respostas.");
            } finally {
                btnSalvar.disabled = false;
                btnSalvar.innerHTML = '<i class="fa-solid fa-paper-plane mr-1"></i> Enviar Respostas';
            }
        });


        // ========================================================
        // MONITORAMENTO EM TEMPO REAL DA ENQUETE (COORDENADOR)
        // ========================================================
        function ouvirRespostasEnquetePainel() {
            // Mapeamento de rótulos amigáveis para visualização
            const labelHorarios = {
                terca_19: "Terça 19h",
                quinta_17: "Quinta 17h",
                sabado_19: "Sábado 19h",
                domingo_09: "Dom 09h",
                domingo_19: "Dom 19h"
            };

            onSnapshot(collection(db, "votos_enquete_sumario"), (snapshot) => {
                const containerNomes = document.getElementById('lista-nomes-enquete');
                containerNomes.innerHTML = "";

                if (snapshot.empty) {
                    containerNomes.innerHTML = `<span class="text-gray-400 italic">Nenhum voto computado ainda neste bloco.</span>`;
                    return;
                }

                snapshot.forEach((docSnap) => {
                    const voto = docSnap.data();
                    const listaTraduzida = voto.horariosDisponiveis.map(h => labelHorarios[h] || h).join(', ');
                    
                    if (voto.horariosDisponiveis.length > 0) {
                        containerNomes.innerHTML += `
                            <div class="text-emerald-800 bg-emerald-50 p-1.5 rounded text-[11px] border border-emerald-100">
                                <i class="fa-solid fa-clock mr-1"></i> <strong>${voto.nomeMembro}:</strong> Disponível em: <span class="underline font-semibold">${listaTraduzida}</span>
                            </div>`;
                    } else {
                        containerNomes.innerHTML += `
                            <div class="text-gray-500 bg-gray-100 p-1.5 rounded text-[11px] border">
                                <i class="fa-solid fa-ban mr-1"></i> <strong>${voto.nomeMembro}:</strong> Indisponível para todos os horários.
                            </div>`;
                    }
                });
            });
        }

        // DISPARAR / FECHAR ENQUETE
        document.getElementById('btn-disparar-enquete').addEventListener('click', async () => {
            await setDoc(doc(db, "enquetes", "disponibilidade_atual"), {
                pergunta: document.getElementById('enq-pergunta').value,
                ativa: true
            });
            alert("Pesquisa por dias e horários aberta para os coroinhas!");
        });

        document.getElementById('btn-fechar-enquete').addEventListener('click', async () => {
            await updateDoc(doc(db, "enquetes", "disponibilidade_atual"), { ativa: false });
            alert("Enquete encerrada.");
        });


        // ========================================================
        // FUNÇÕES ADICIONAIS DO SISTEMA ADMIN (MANTIDAS INTACTAS)
        // ========================================================
        document.getElementById('btn-gerar-senha').addEventListener('click', () => {
            const caracteres = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789@#%';
            let novaSenha = '';
            for (let i = 0; i < 8; i++) { novaSenha += caracteres.charAt(Math.floor(Math.random() * caracteres.length)); }
            document.getElementById('cad-senha').value = novaSenha;
        });

        function ouvirUsuariosCadastrados() {
            onSnapshot(collection(db, "usuarios"), (snapshot) => {
                const tabelaBody = document.getElementById('tabela-usuarios-recuperacao');
                tabelaBody.innerHTML = "";
                snapshot.forEach((docSnap) => {
                    const usuario = docSnap.data();
                    const senhaExibida = usuario.funcao === "Coordenador" ? "•••••••• (Protegida)" : (usuario.senha_provisoria || "Sem registro");
                    tabelaBody.innerHTML += `
                        <tr class="hover:bg-gray-50/80 transition-all border-b border-gray-100">
                            <td class="p-3 font-semibold text-gray-800">${usuario.nome}</td>
                            <td class="p-3 text-gray-600 font-mono">${usuario.email}</td>
                            <td class="p-3 text-amber-900 bg-amber-50/40 font-mono font-bold select-all">${senhaExibida}</td>
                            <td class="p-3 text-center">
                                <span class="px-2 py-0.5 text-[10px] font-bold rounded-sm ${usuario.funcao === 'Coordenador' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800'}">${usuario.funcao}</span>
                            </td>
                        </tr>`;
                });
            });
        }

        document.getElementById('form-cadastro-usuario').addEventListener('submit', async (e) => {
            e.preventDefault();
            const nome = document.getElementById('cad-nome').value;
            const email = document.getElementById('cad-email').value;
            const senha = document.getElementById('cad-senha').value;
            try {
                const credencial = await createUserWithEmailAndPassword(auth, email, senha);
                await setDoc(doc(db, "usuarios", credencial.user.uid), { nome: nome, email: email, funcao: "Coroinha", senha_provisoria: senha });
                alert(`Membro ${nome} registrado com sucesso!`);
                document.getElementById('form-cadastro-usuario').reset();
            } catch (err) { alert("Falha no registro: " + err.message); }
        });

        async function carregarEscalaPorData(dataString) {
            dataSelecionadaGlobal = dataString;
            const docSnap = await getDoc(doc(db, "escalas", dataString));
            const lista = document.getElementById('lista-presbiterio');
            const cardNotificacao = document.getElementById('card-notificacao');

            if (docSnap.exists()) {
                const dados = docSnap.data();
                document.getElementById('lbl-data-missa').innerText = dataString.split('-').reverse().join('/');
                document.getElementById('lbl-titulo-missa').innerText = dados.titulo;
                document.getElementById('lbl-horario-missa').innerText = dados.horario + "h";
                
                lista.innerHTML = `
                    <div class="p-3 flex items-center justify-between">
                        <div><p class="text-xs text-gray-400 font-bold uppercase">Turiferário</p><p class="font-medium text-sm text-gray-800">${dados.turiferario.nome}</p></div>
                        <span class="text-[10px] font-bold px-2 py-1 rounded-full ${dados.turiferario.status === 'Confirmado' ? 'bg-emerald-100 text-emerald-800' : dados.turiferario.status === 'Pendente' ? 'bg-amber-100 text-amber-800' : 'bg-rose-100 text-rose-800'}">${dados.turiferario.status}</span>
                    </div>
                    <div class="p-3 flex items-center justify-between">
                        <div><p class="text-xs text-gray-400 font-bold uppercase">Naveteiro</p><p class="font-medium text-sm text-gray-800">${dados.naveteiro.nome}</p></div>
                        <span class="text-[10px] font-bold px-2 py-1 rounded-full ${dados.naveteiro.status === 'Confirmado' ? 'bg-emerald-100 text-emerald-800' : dados.naveteiro.status === 'Pendente' ? 'bg-amber-100 text-amber-800' : 'bg-rose-100 text-rose-800'}">${dados.naveteiro.status}</span>
                    </div>
                    <div class="p-3 flex items-center justify-between">
                        <div><p class="text-xs text-gray-400 font-bold uppercase">Crucífero</p><p class="font-medium text-sm text-gray-800">${dados.crucifero.nome}</p></div>
                        <span class="text-[10px] font-bold px-2 py-1 rounded-full ${dados.crucifero.status === 'Confirmado' ? 'bg-emerald-100 text-emerald-800' : dados.crucifero.status === 'Pendente' ? 'bg-amber-100 text-amber-800' : 'bg-rose-100 text-rose-800'}">${dados.crucifero.status}</span>
                    </div>`;

                if(usuarioLogadoDados && (dados.turiferario.nome === usuarioLogadoDados.nome || dados.naveteiro.nome === usuarioLogadoDados.nome || dados.crucifero.nome === usuarioLogadoDados.nome)) {
                    cardNotificacao.classList.remove('hidden');
                    document.getElementById('botoes-acao').classList.remove('hidden');
                    document.getElementById('txt-feedback').classList.add('hidden');
                } else { cardNotificacao.classList.add('hidden'); }
            } else {
                document.getElementById('lbl-data-missa').innerText = "--/--/----";
                document.getElementById('lbl-titulo-missa').innerText = "Sem escala publicada";
                document.getElementById('lbl-horario-missa').innerText = "--:--h";
                lista.innerHTML = `<p class="text-xs text-gray-400 text-center py-6">Nenhum acólito escalado para este dia.</p>`;
                cardNotificacao.classList.add('hidden');
            }
        }

        buscaEscalaData.addEventListener('change', (e) => carregarEscalaPorData(e.target.value));

        async function responderEscala(statusNovo) {
            const docRef = doc(db, "escalas", dataSelecionadaGlobal);
            const docSnap = await getDoc(docRef);
            if (!docSnap.exists()) return;
            const dados = docSnap.data();

            let updateCampos = {};
            if (dados.turiferario.nome === usuarioLogadoDados.nome) updateCampos = { "turiferario.status": statusNovo };
            if (dados.naveteiro.nome === usuarioLogadoDados.nome) updateCampos = { "naveteiro.status": statusNovo };
            if (dados.crucifero.nome === usuarioLogadoDados.nome) updateCampos = { "crucifero.status": statusNovo };

            await updateDoc(docRef, updateCampos);
            document.getElementById('botoes-acao').classList.add('hidden');
            const feedback = document.getElementById('txt-feedback');
            feedback.className = `text-xs font-bold mt-2 ${statusNovo === 'Confirmado' ? 'text-emerald-600' : 'text-rose-600'}`;
            feedback.innerText = statusNovo === 'Confirmado' ? "✓ Presença confirmada no banco!" : "✕ Solicitação enviada.";
            feedback.classList.remove('hidden');
            carregarEscalaPorData(dataSelecionadaGlobal);
        }

        document.getElementById('btn-confirmar').addEventListener('click', () => responderEscala('Confirmado'));
        document.getElementById('btn-recusar').addEventListener('click', () => responderEscala('Substituição Solicitada'));

        async function carregarMaterialEstudo() {
            const docSnap = await getDoc(doc(db, "formacao", "manual_atual"));
            if (docSnap.exists()) {
                document.getElementById('lbl-titulo-formacao').innerText = docSnap.data().titulo;
                document.getElementById('btn-download-formacao').href = docSnap.data().url;
            }
        }

        async function carregarLiturgiaAutomatica() {
            try {
                const res = await fetch('https://liturgia.up.railway.app/');
                const data = await res.json();
                document.getElementById('lbl-ref-liturgia').innerText = data.evangelho.referencia;
                document.getElementById('txt-evangelho-dia').innerText = data.evangelho.texto;
            } catch (err) { document.getElementById('txt-evangelho-dia').innerText = "Consulta disponível na sacristia."; }
        }

        document.getElementById('form-nova-escala').addEventListener('submit', async (e) => {
            e.preventDefault();
            const dataFila = document.getElementById('esc-data').value;
            try {
                await setDoc(doc(db, "escalas", dataFila), {
                    titulo: document.getElementById('esc-titulo').value,
                    horario: document.getElementById('esc-horario').value,
                    data: dataFila,
                    turiferario: { nome: document.getElementById('esc-turi').value, status: "Pendente" },
                    naveteiro: { nome: document.getElementById('esc-nave').value, status: "Pendente" },
                    crucifero: { nome: document.getElementById('esc-cruz').value, status: "Pendente" }
                });
                alert("Escala salva!");
                document.getElementById('form-nova-escala').reset();
            } catch (err) { alert("Erro: " + err.message); }
        });

        document.getElementById('form-upload-formacao').addEventListener('submit', async (e) => {
            e.preventDefault();
            await setDoc(doc(db, "formacao", "manual_atual"), {
                titulo: document.getElementById('form-titulo-input').value,
                url: document.getElementById('form-url-input').value
            });
            alert("Material atualizado!");
            document.getElementById('form-upload-formacao').reset();
        });

        window.switchTab = function(tabName) {
            if (usuarioLogadoDados?.funcao === "Coordenador") return;
            document.getElementById('conteudo-escala').className = tabName === 'escala' ? 'space-y-4 block' : 'space-y-4 hidden';
            document.getElementById('conteudo-avisos').className = tabName === 'avisos' ? 'space-y-4 block md:block' : 'space-y-4 hidden md:block';
            document.getElementById('conteudo-liturgia').className = tabName === 'liturgia' ? 'space-y-4 block md:block' : 'space-y-4 hidden md:block';
            
            document.getElementById('tab-escala').className = tabName === 'escala' ? 'active-tab flex-1 py-3 text-center text-sm flex flex-col items-center gap-1' : 'text-gray-500 flex-1 py-3 text-center text-sm flex flex-col items-center gap-1';
            document.getElementById('tab-avisos').className = tabName === 'avisos' ? 'active-tab flex-1 py-3 text-center text-sm flex flex-col items-center gap-1' : 'text-gray-500 flex-1 py-3 text-center text-sm flex flex-col items-center gap-1';
            document.getElementById('tab-liturgia').className = tabName === 'liturgia' ? 'active-tab flex-1 py-3 text-center text-sm flex flex-col items-center gap-1' : 'text-gray-500 flex-1 py-3 text-center text-sm flex flex-col items-center gap-1';
        }
    </script>
    <script>
        document.getElementById('tab-escala').addEventListener('click', () => switchTab('escala'));
        document.getElementById('tab-avisos').addEventListener('click', () => switchTab('avisos'));
        document.getElementById('tab-liturgia').addEventListener('click', () => switchTab('liturgia'));
    </script>
</body>
</html>
